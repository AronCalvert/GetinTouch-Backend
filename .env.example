# Database Configuration
POSTGRES_USER=getintouch_user
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=getintouch_db

# Spring Boot Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/getintouch_db
SPRING_DATASOURCE_USERNAME=getintouch_user
SPRING_DATASOURCE_PASSWORD=change_this_to_a_secure_password

# JWT Configuration - Generate a random string minimum 32 characters
JWT_SECRET=your_very_long_random_secret_key_minimum_32_characters
JWT_EXPIRATION=3600000

# Admin Configuration - Change to a secure secret
ADMIN_SECRET=your_admin_secret_key

# Environment Profile (dev, test, prod)
SPRING_PROFILES_ACTIVE=dev

# Logging Levels (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_SPRING_SECURITY=WARN
LOGGING_LEVEL_SPRING_WEB=INFO
LOGGING_LEVEL_APP=INFO
